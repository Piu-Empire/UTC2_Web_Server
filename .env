# Server
SERVER_PORT=8080
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD={noop}admin

# Database (Dùng tên service 'mysql-db' thay vì localhost)
DB_URL=jdbc:mysql://mysql-db:3306/utc2app?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=1234
DB_DRIVER=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# Flyway
FLYWAY_ENABLED=true
FLYWAY_LOCATIONS=classpath:db/migration

# JWT
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long_random_string_here
JWT_EXPIRATION=86400000

# Logging
LOG_FILE=logs/app.log
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# Swagger
API_DOCS_PATH=/api-docs
SWAGGER_UI_PATH=/swagger-ui.html